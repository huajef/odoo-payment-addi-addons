<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Widget y botón en página de producto -->
    <template id="addi_widget_product" inherit_id="website_sale.product" name="Addi - Widget en producto">
        <xpath expr="//div[@id='product_details']" position="inside">
            <!-- Widget visual de Addi (de la documentación) -->
            <addi-widget
                t-att-price="addi_amount"
                t-att-ally-slug="addi_provider.addi_ally_slug if addi_provider and addi_provider.addi_ally_slug else 'tu-ally-slug'"
                class="mb-3 d-block"
            />
            
            <!-- Botón de pago directo -->
            <div class="addi-pay-container mt-2" t-if="addi_amount and addi_amount > 0">
                <button
                    type="button"
                    id="addi_pay_button"
                    class="btn btn-primary w-100"
                    t-att-data-amount="addi_amount"
                    t-att-data-currency-id="addi_currency_id"
                    t-att-data-partner-id="addi_partner_id"
                    data-addi-pay="1"
                >
                    Pagar con Addi
                </button>
            </div>
        </xpath>
    </template>
</odoo>
