<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Widget de Addi en la página de producto.
        Se hereda de website_sale.product y se inserta el bloque
        justo debajo del precio del producto.

        La sección está envuelta en t-if para que sólo aparezca
        cuando el proveedor Addi esté activo.
    -->
    <template
        id="addi_widget_product"
        inherit_id="website_sale.product"
        name="Addi – Widget en producto"
    >
        <!--
            Insertar después del bloque de precio (#product_price).
            Usamos un selector CSS robusto que existe en Odoo 18.
        -->
        <xpath expr="//div[@id='product_details']" position="inside">
            <t t-if="addi_provider and addi_provider.state in ('enabled', 'test') and addi_provider.addi_ally_slug">
                <!-- Script del widget de Addi (se carga una sola vez) -->
                <script
                    src="https://s3.amazonaws.com/widgets.addi.com/bundle.min.js"
                    type="text/javascript"
                    defer="defer"
                />

                <!-- Contenedor del widget -->
                <div class="addi-widget-container mt-3">
                    <addi-widget
                        t-att-price="product.lst_price"
                        t-att-ally-slug="addi_provider.addi_ally_slug"
                    />
                </div>

                <!-- Botón de pago con Addi -->
                <div class="addi-pay-container mt-2">
                    <button
                        type="button"
                        class="btn addi-pay-btn w-100"
                        style="background-color:#f5a623;color:#fff;font-weight:600;"
                        t-att-data-amount="product.lst_price"
                        t-att-data-currency-id="product.currency_id.id"
                        t-att-data-product-id="product.id"
                        data-addi-pay="1"
                    >
                        Pagar con Addi
                    </button>
                </div>
            </t>
        </xpath>
    </template>

    <!--
        Inyectar la variable addi_provider en el contexto del template.
        Se sobreescribe el método get_sale_product_domain desde el
        controlador de website_sale o se usa un QWeb ir.ui.view global.
    -->
</odoo>
