<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="payment_method_addi" model="payment.method">
            <field name="name">Addi</field>
            <field name="code">addi</field>
            <field name="sequence">999</field>
            <field name="active">True</field>
            <!-- <field name="image" type="base64" file="payment_addi/static/img/addi.png"/> -->
            <field name="support_tokenization">False</field>
            <field name="support_express_checkout">False</field>
            <field name="support_refund">none</field>
            <field name="supported_country_ids"
                eval="[Command.set([ref('base.co')])]"
            />
            <field name="supported_currency_ids"
                eval="[Command.set([ref('base.COP')])]"
            />
        </record>

    </data>
</odoo>